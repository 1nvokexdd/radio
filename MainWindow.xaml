<Window x:Class="RadioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio Player" Height="200" Width="400">
    <StackPanel Margin="10">
        <TextBlock Text="URL радиостанции:"/>
        <TextBox Name="UrlBox"
                 Text="http://ice1.somafm.com/groovesalad-128-mp3"
                 Margin="0,5,0,10" />
        <StackPanel Orientation="Horizontal" Margin="0,5">
            <Button Content="Start" Width="100" Click="Start_Click"/>
            <Button Content="Stop" Width="100" Margin="10,0,0,0" Click="Stop_Click"/>
        </StackPanel>

        <TextBlock Name="StatusText" Margin="0,10,0,0" Text="Статус: ожидание" />
        
    </StackPanel>
</Window>